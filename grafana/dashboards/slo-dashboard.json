          "refId": "A"
        }
      ],
      "title": "SLO: decisions (allowed / rejected / fallback × algorithm)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.002 },
              { "color": "red", "value": 0.01 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum(rate(ratelimiter_redis_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99 redis",
          "refId": "A"
        }
      ],
      "title": "SLO: Redis p99 (target < 2ms; alert if > 10ms)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "unit": "none" } },
